{
  "manifest_version": 3,
  "name": "Integrator for Moodle & NTU COOL",
  "version": "1.1",
  "description": "將台科大 Moodle 課程整併至NTU COOL 頁面，支援自訂連結",
  "icons": {
    "16": "image/16.png",
    "48": "image/48.png",
    "128": "image/128.png"
  },
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://moodle2.ntust.edu.tw/my/courses.php*"],
      "js": ["moodle.js"]
    },
    {
      "matches": ["https://cool.ntu.edu.tw/*"],
      "js": ["cool.js"]
    }
  ]
}
